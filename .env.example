# VaultAuth OAuth provider base URL
VAULTAUTH_URL=http://localhost:3000

# Client credentials — register at http://localhost:3001/developer
# Redirect URI to register: http://localhost:3002/api/auth/callback/vaultauth
VAULTAUTH_CLIENT_ID=
VAULTAUTH_CLIENT_SECRET=

# NextAuth v5 — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3002

# App URL (used for redirects in the UI)
NEXT_PUBLIC_APP_URL=http://localhost:3002
